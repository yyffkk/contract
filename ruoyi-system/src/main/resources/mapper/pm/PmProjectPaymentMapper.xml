<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.pm.mapper.PmProjectPaymentMapper">
    
    <resultMap type="PmProjectPayment" id="PmProjectPaymentResult">
        <result property="id"    column="id"    />
        <result property="projectId"    column="project_id"    />
        <result property="paymentId"    column="payment_id"    />
        <result property="paymentName"    column="payment_name"    />
        <result property="paymentAmount"    column="payment_amount"    />
        <result property="paymentType"    column="payment_type"    />
        <result property="paymentDate"    column="payment_date"    />
        <result property="createTime"    column="create_time"    />
        <result property="createBy"    column="create_by"    />
    </resultMap>

    <sql id="selectPmProjectPaymentVo">
        select id, project_id, payment_id, payment_name, payment_amount, payment_type, payment_date, create_time, create_by from pm_project_payment
    </sql>

    <select id="selectPmProjectPaymentList" parameterType="PmProjectPayment" resultMap="PmProjectPaymentResult">
        <include refid="selectPmProjectPaymentVo"/>
        <where>  
            <if test="projectId != null "> and project_id = #{projectId}</if>
            <if test="paymentId != null "> and payment_id = #{paymentId}</if>
            <if test="paymentName != null  and paymentName != ''"> and payment_name like concat('%', #{paymentName}, '%')</if>
            <if test="paymentAmount != null "> and payment_amount = #{paymentAmount}</if>
            <if test="paymentType != null  and paymentType != ''"> and payment_type = #{paymentType}</if>
            <if test="paymentDate != null "> and payment_date = #{paymentDate}</if>
        </where>
    </select>
    
    <select id="selectPmProjectPaymentById" parameterType="Long" resultMap="PmProjectPaymentResult">
        <include refid="selectPmProjectPaymentVo"/>
        where id = #{id}
    </select>

    <insert id="insertPmProjectPayment" parameterType="PmProjectPayment" useGeneratedKeys="true" keyProperty="id">
        insert into pm_project_payment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="paymentId != null">payment_id,</if>
            <if test="paymentName != null">payment_name,</if>
            <if test="paymentAmount != null">payment_amount,</if>
            <if test="paymentType != null">payment_type,</if>
            <if test="paymentDate != null">payment_date,</if>
            <if test="createTime != null">create_time,</if>
            <if test="createBy != null">create_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="paymentId != null">#{paymentId},</if>
            <if test="paymentName != null">#{paymentName},</if>
            <if test="paymentAmount != null">#{paymentAmount},</if>
            <if test="paymentType != null">#{paymentType},</if>
            <if test="paymentDate != null">#{paymentDate},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="createBy != null">#{createBy},</if>
         </trim>
    </insert>

    <update id="updatePmProjectPayment" parameterType="PmProjectPayment">
        update pm_project_payment
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="paymentId != null">payment_id = #{paymentId},</if>
            <if test="paymentName != null">payment_name = #{paymentName},</if>
            <if test="paymentAmount != null">payment_amount = #{paymentAmount},</if>
            <if test="paymentType != null">payment_type = #{paymentType},</if>
            <if test="paymentDate != null">payment_date = #{paymentDate},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePmProjectPaymentById" parameterType="Long">
        delete from pm_project_payment where id = #{id}
    </delete>

    <delete id="deletePmProjectPaymentByIds" parameterType="String">
        delete from pm_project_payment where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>