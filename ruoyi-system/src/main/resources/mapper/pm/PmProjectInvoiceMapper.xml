<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.pm.mapper.PmProjectInvoiceMapper">
    
    <resultMap type="PmProjectInvoice" id="PmProjectInvoiceResult">
        <result property="id"    column="id"    />
        <result property="projectId"    column="project_id"    />
        <result property="invoiceId"    column="invoice_id"    />
        <result property="invoiceCode"    column="invoice_code"    />
        <result property="invoiceNumber"    column="invoice_number"    />
        <result property="invoiceAmount"    column="invoice_amount"    />
        <result property="invoiceType"    column="invoice_type"    />
        <result property="invoiceDate"    column="invoice_date"    />
        <result property="createTime"    column="create_time"    />
        <result property="createBy"    column="create_by"    />
    </resultMap>

    <sql id="selectPmProjectInvoiceVo">
        select id, project_id, invoice_id, invoice_code, invoice_number, invoice_amount, invoice_type, invoice_date, create_time, create_by from pm_project_invoice
    </sql>

    <select id="selectPmProjectInvoiceList" parameterType="PmProjectInvoice" resultMap="PmProjectInvoiceResult">
        <include refid="selectPmProjectInvoiceVo"/>
        <where>  
            <if test="projectId != null "> and project_id = #{projectId}</if>
            <if test="invoiceId != null "> and invoice_id = #{invoiceId}</if>
            <if test="invoiceCode != null  and invoiceCode != ''"> and invoice_code = #{invoiceCode}</if>
            <if test="invoiceNumber != null  and invoiceNumber != ''"> and invoice_number = #{invoiceNumber}</if>
            <if test="invoiceAmount != null "> and invoice_amount = #{invoiceAmount}</if>
            <if test="invoiceType != null  and invoiceType != ''"> and invoice_type = #{invoiceType}</if>
            <if test="invoiceDate != null "> and invoice_date = #{invoiceDate}</if>
        </where>
    </select>
    
    <select id="selectPmProjectInvoiceById" parameterType="Long" resultMap="PmProjectInvoiceResult">
        <include refid="selectPmProjectInvoiceVo"/>
        where id = #{id}
    </select>

    <insert id="insertPmProjectInvoice" parameterType="PmProjectInvoice" useGeneratedKeys="true" keyProperty="id">
        insert into pm_project_invoice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="invoiceId != null">invoice_id,</if>
            <if test="invoiceCode != null">invoice_code,</if>
            <if test="invoiceNumber != null">invoice_number,</if>
            <if test="invoiceAmount != null">invoice_amount,</if>
            <if test="invoiceType != null">invoice_type,</if>
            <if test="invoiceDate != null">invoice_date,</if>
            <if test="createTime != null">create_time,</if>
            <if test="createBy != null">create_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="invoiceId != null">#{invoiceId},</if>
            <if test="invoiceCode != null">#{invoiceCode},</if>
            <if test="invoiceNumber != null">#{invoiceNumber},</if>
            <if test="invoiceAmount != null">#{invoiceAmount},</if>
            <if test="invoiceType != null">#{invoiceType},</if>
            <if test="invoiceDate != null">#{invoiceDate},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="createBy != null">#{createBy},</if>
         </trim>
    </insert>

    <update id="updatePmProjectInvoice" parameterType="PmProjectInvoice">
        update pm_project_invoice
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="invoiceId != null">invoice_id = #{invoiceId},</if>
            <if test="invoiceCode != null">invoice_code = #{invoiceCode},</if>
            <if test="invoiceNumber != null">invoice_number = #{invoiceNumber},</if>
            <if test="invoiceAmount != null">invoice_amount = #{invoiceAmount},</if>
            <if test="invoiceType != null">invoice_type = #{invoiceType},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePmProjectInvoiceById" parameterType="Long">
        delete from pm_project_invoice where id = #{id}
    </delete>

    <delete id="deletePmProjectInvoiceByIds" parameterType="String">
        delete from pm_project_invoice where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>