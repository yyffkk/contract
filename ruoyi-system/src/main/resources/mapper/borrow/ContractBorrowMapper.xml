<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.borrow.mapper.ContractBorrowMapper">
    
    <resultMap type="ContractBorrow" id="ContractBorrowResult">
        <result property="id"    column="id"    />
        <result property="contractId"    column="contract_id"    />
        <result property="borrowNo"    column="borrow_no"    />
        <result property="borrower"    column="borrower"    />
        <result property="borrowDepartment"    column="borrow_department"    />
        <result property="borrowDate"    column="borrow_date"    />
        <result property="expectedReturnDate"    column="expected_return_date"    />
        <result property="actualReturnDate"    column="actual_return_date"    />
        <result property="borrowReason"    column="borrow_reason"    />
        <result property="contractName"    column="contract_name"    />
        <result property="contractNumber"    column="contract_number"    />
        <result property="contractType"    column="contract_type"    />
        <result property="contractAmount"    column="contract_amount"    />
        <result property="ourParty"    column="our_party"    />
        <result property="otherParty"    column="other_party"    />
        <result property="status"    column="status"    />
        <result property="approvalStatus"    column="approval_status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectContractBorrowVo">
        select id, contract_id, borrow_no, borrower, borrow_department, borrow_date, expected_return_date, actual_return_date, borrow_reason, contract_name, contract_number, contract_type, contract_amount, our_party, other_party, status, approval_status, remark, create_by, create_time, update_by, update_time, del_flag from contract_borrow
    </sql>

    <select id="selectContractBorrowList" parameterType="ContractBorrow" resultMap="ContractBorrowResult">
        <include refid="selectContractBorrowVo"/>
        <where>  
            <if test="contractId != null "> and contract_id = #{contractId}</if>
            <if test="borrowNo != null  and borrowNo != ''"> and borrow_no = #{borrowNo}</if>
            <if test="borrower != null  and borrower != ''"> and borrower = #{borrower}</if>
            <if test="borrowDepartment != null  and borrowDepartment != ''"> and borrow_department = #{borrowDepartment}</if>
            <if test="borrowDate != null "> and borrow_date = #{borrowDate}</if>
            <if test="expectedReturnDate != null "> and expected_return_date = #{expectedReturnDate}</if>
            <if test="actualReturnDate != null "> and actual_return_date = #{actualReturnDate}</if>
            <if test="borrowReason != null  and borrowReason != ''"> and borrow_reason = #{borrowReason}</if>
            <if test="contractName != null  and contractName != ''"> and contract_name like concat('%', #{contractName}, '%')</if>
            <if test="contractNumber != null  and contractNumber != ''"> and contract_number = #{contractNumber}</if>
            <if test="contractType != null  and contractType != ''"> and contract_type = #{contractType}</if>
            <if test="contractAmount != null "> and contract_amount = #{contractAmount}</if>
            <if test="ourParty != null  and ourParty != ''"> and our_party = #{ourParty}</if>
            <if test="otherParty != null  and otherParty != ''"> and other_party = #{otherParty}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="approvalStatus != null  and approvalStatus != ''"> and approval_status = #{approvalStatus}</if>
        </where>
    </select>
    
    <select id="selectContractBorrowById" parameterType="Long" resultMap="ContractBorrowResult">
        <include refid="selectContractBorrowVo"/>
        where id = #{id}
    </select>

    <insert id="insertContractBorrow" parameterType="ContractBorrow" useGeneratedKeys="true" keyProperty="id">
        insert into contract_borrow
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="contractId != null">contract_id,</if>
            <if test="borrowNo != null">borrow_no,</if>
            <if test="borrower != null">borrower,</if>
            <if test="borrowDepartment != null">borrow_department,</if>
            <if test="borrowDate != null">borrow_date,</if>
            <if test="expectedReturnDate != null">expected_return_date,</if>
            <if test="actualReturnDate != null">actual_return_date,</if>
            <if test="borrowReason != null">borrow_reason,</if>
            <if test="contractName != null">contract_name,</if>
            <if test="contractNumber != null">contract_number,</if>
            <if test="contractType != null">contract_type,</if>
            <if test="contractAmount != null">contract_amount,</if>
            <if test="ourParty != null">our_party,</if>
            <if test="otherParty != null">other_party,</if>
            <if test="status != null">status,</if>
            <if test="approvalStatus != null">approval_status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="contractId != null">#{contractId},</if>
            <if test="borrowNo != null">#{borrowNo},</if>
            <if test="borrower != null">#{borrower},</if>
            <if test="borrowDepartment != null">#{borrowDepartment},</if>
            <if test="borrowDate != null">#{borrowDate},</if>
            <if test="expectedReturnDate != null">#{expectedReturnDate},</if>
            <if test="actualReturnDate != null">#{actualReturnDate},</if>
            <if test="borrowReason != null">#{borrowReason},</if>
            <if test="contractName != null">#{contractName},</if>
            <if test="contractNumber != null">#{contractNumber},</if>
            <if test="contractType != null">#{contractType},</if>
            <if test="contractAmount != null">#{contractAmount},</if>
            <if test="ourParty != null">#{ourParty},</if>
            <if test="otherParty != null">#{otherParty},</if>
            <if test="status != null">#{status},</if>
            <if test="approvalStatus != null">#{approvalStatus},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateContractBorrow" parameterType="ContractBorrow">
        update contract_borrow
        <trim prefix="SET" suffixOverrides=",">
            <if test="contractId != null">contract_id = #{contractId},</if>
            <if test="borrowNo != null">borrow_no = #{borrowNo},</if>
            <if test="borrower != null">borrower = #{borrower},</if>
            <if test="borrowDepartment != null">borrow_department = #{borrowDepartment},</if>
            <if test="borrowDate != null">borrow_date = #{borrowDate},</if>
            <if test="expectedReturnDate != null">expected_return_date = #{expectedReturnDate},</if>
            <if test="actualReturnDate != null">actual_return_date = #{actualReturnDate},</if>
            <if test="borrowReason != null">borrow_reason = #{borrowReason},</if>
            <if test="contractName != null">contract_name = #{contractName},</if>
            <if test="contractNumber != null">contract_number = #{contractNumber},</if>
            <if test="contractType != null">contract_type = #{contractType},</if>
            <if test="contractAmount != null">contract_amount = #{contractAmount},</if>
            <if test="ourParty != null">our_party = #{ourParty},</if>
            <if test="otherParty != null">other_party = #{otherParty},</if>
            <if test="status != null">status = #{status},</if>
            <if test="approvalStatus != null">approval_status = #{approvalStatus},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteContractBorrowById" parameterType="Long">
        delete from contract_borrow where id = #{id}
    </delete>

    <delete id="deleteContractBorrowByIds" parameterType="String">
        delete from contract_borrow where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>